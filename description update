UPDATE your_table
SET description = REGEXP_REPLACE(
    REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(description, 
        '\r\n', ' '), 
        '\r', ' '), 
        '\n', ' '), 
        '\t', ' '), 
        UNHEX('C2A0'), ' '),
    ' {2,}',
    ' '
);


