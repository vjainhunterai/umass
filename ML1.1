    def pairwise_clustering(df, index_col = 'Index_row', matching_col = 'matching_index',cluster_col = 'cluster_id' ):
        df_result = df.copy()
        def parse_matches(x):

            return ast.literal_eval(x) if pd.notnull(x) else []
        df_result[matching_col] = df_result[matching_col].apply(parse_matches)
        G = nx.Graph()
        all_indices = sorted(df_result[index_col].unique())
        G.add_nodes_from(all_indices)

        index_to_neighbors = {}
        for i, row in df_result.iterrows():
            current_idx = row[index_col]
            neighbors = sorted(row[matching_col])
            index_to_neighbors[current_idx] = neighbors
        for node, neighbors in index_to_neighbors.items():
            for nb in neighbors:
                G.add_edge(node, nb)
        global forced_pairs
        forced_pairs = []

        while True:
            single_neighbor_nodes = sorted([n for n in G.nodes if G.degree(n) ==1])
            if not single_neighbor_nodes:
                break
            single_neighbor_nodes.sort()
            for node in single_neighbor_nodes:
                if node in G:
                    neighbor_list = list(G[node])
                    if len(neighbor_list) ==1:
                        partner = neighbor_list[0]
                        forced_pairs.append(tuple(sorted((node,partner))))
                        G.remove_node(node)
                        if partner in G:
                            G.remove_node(partner)
        max_match = nx.max_weight_matching(G,maxcardinality = True)
        matched_pairs = [tuple(sorted(list(edge))) for edge in max_match]
        all_pairs = forced_pairs + matched_pairs
        global cluster_id_map
        cluster_id_map = {}
        current_cluster_id = 1
        for pair in sorted(all_pairs):
            u, v = pair
            cluster_id_map[u] = current_cluster_id
            cluster_id_map[v] = current_cluster_id
            current_cluster_id +=1
        def get_cluster_id(row, idx):
            return cluster_id_map.get(row_idx, None)
        df_result[cluster_col] = df_result[index_col].apply(lambda x: cluster_id_map.get(x,None))
        return df_result

